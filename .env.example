# =============================================================================
# Hibernate N+1 Detector MCP — Database Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
#
# cp .env.example .env
# =============================================================================

# Database type: "postgresql" | "mysql"
DB_TYPE=postgresql

# Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=your_database_name
DB_USER=your_username
DB_PASSWORD=your_password

# SSL (true | false | "require" | "prefer")
DB_SSL=false

# Connection pool
DB_POOL_MIN=1
DB_POOL_MAX=3

# Query timeout in ms (default: 10000)
DB_QUERY_TIMEOUT=10000

# Optional: schema (PostgreSQL only, leave blank for default "public")
DB_SCHEMA=public
